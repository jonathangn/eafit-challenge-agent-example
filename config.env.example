# Copy to config.env and fill in your values
# DO NOT commit config.env (already in .gitignore)

# LLM
LLM_PROVIDER="openai"
OPENAI_MODEL="deepseek-chat"
OPENAI_API_KEY="sk-your-deepseek-api-key-here"
OPENAI_BASE_URL="https://api.deepseek.com/v1"

# Chatbot
CHATBOT_PORT="3003"
CHATBOT_IMAGE="io2060/hologram-generic-ai-agent-app:latest"

# VS Agent
VS_AGENT_IMAGE="veranalabs/vs-agent:latest"
VS_AGENT_ADMIN_PORT="3010"
VS_AGENT_PUBLIC_PORT="3011"

# Database
POSTGRES_DB="personal-aissistant"
POSTGRES_USER="personal_aiassistant_db"
POSTGRES_PASSWORD="changeme"

# ngrok
NGROK_DOMAIN="your-ngrok-domain.ngrok-free.app"

# Credential
CREDENTIAL_DEFINITION_ID=""
